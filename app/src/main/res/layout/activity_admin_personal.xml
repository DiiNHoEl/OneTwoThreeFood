<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainAdminPersonal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textTituloAdminPersonal"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#E91E63"
            android:gravity="center"
            android:text="Administrar Personal"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/editId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="ID"
            android:inputType="number"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="NOMBRE"
            android:inputType="textPersonName"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editUsuarioAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="USUARIO"
            android:inputType="textPersonName"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editContrasenaAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="CONTRASEÑA"
            android:inputType="textPassword"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editRol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="ROL (admin, mesero, cajero, cocina)"
            android:inputType="text"
            android:padding="15dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrarUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#E91E63"
            android:text="REGISTRAR USUARIO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsultarId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#3F51B5"
            android:text="CONSULTAR POR ID"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsultarNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#009688"
            android:text="CONSULTAR POR NOMBRE"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsultarUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF9800"
            android:text="CONSULTAR POR USUARIO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActualizarUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#795548"
            android:text="ACTUALIZAR INFORMACIÓN"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#B71C1C"
            android:text="ELIMINAR USUARIO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegresarAdminPersonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#616161"
            android:text="REGRESAR"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/textResultadoAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:padding="15dp"
            android:text="Aquí se mostrarán los resultados..."
            android:textColor="#000000"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progressBarAdmin"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>