<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainAdminPlatillos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textTituloAdminPlatillos"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#009688"
            android:gravity="center"
            android:text="Administrar Platillos"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/editIdPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="ID"
            android:inputType="number"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editNombrePlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="NOMBRE DEL PLATILLO"
            android:inputType="text"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editDescripcionPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="DESCRIPCIÓN"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editPrecioPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="PRECIO"
            android:inputType="numberDecimal"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editCategoriaPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="CATEGORÍA"
            android:inputType="text"
            android:padding="15dp" />

        <EditText
            android:id="@+id/editDisponiblePlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="DISPONIBLE (si o no)"
            android:inputType="text"
            android:padding="15dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrarPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#009688"
            android:text="REGISTRAR PLATILLO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsultarPlatillos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#3F51B5"
            android:text="CONSULTAR TODOS"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsultarPlatilloPorId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF9800"
            android:text="CONSULTAR POR ID"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActualizarPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#795548"
            android:text="ACTUALIZAR PLATILLO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarPlatillo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#B71C1C"
            android:text="ELIMINAR PLATILLO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegresarAdminPlatillos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#616161"
            android:text="REGRESAR"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/textResultadoAdminPlatillos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:padding="15dp"
            android:text="Aquí se mostrarán los resultados..."
            android:textColor="#000000"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progressBarAdminPlatillos"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>