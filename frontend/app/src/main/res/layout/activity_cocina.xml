<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainCocina"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textTituloCocina"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#795548"
            android:gravity="center"
            android:text="Módulo Cocina"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/textUsuarioCocina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Usuario de cocina:"
            android:textColor="#000000"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/editIdComandaCocina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:hint="ID DE COMANDA"
            android:inputType="number"
            android:padding="15dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConsultarComandasCocina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#795548"
            android:text="CONSULTAR PEDIDOS PENDIENTES"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCambiarPreparando"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF9800"
            android:text="CAMBIAR A PREPARANDO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCambiarListo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#4CAF50"
            android:text="CAMBIAR A LISTO"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarSesionCocina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#616161"
            android:text="CERRAR SESIÓN"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/textResultadoCocina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:padding="15dp"
            android:text="Aquí se mostrarán los pedidos pendientes..."
            android:textColor="#000000"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progressBarCocina"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>